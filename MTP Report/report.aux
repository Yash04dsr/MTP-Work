\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Matched-pair angle effect. Each pair shares the independent \((\ensuremath  {d/D},\ensuremath  {\mathrm  {VR}})\) (and therefore the derived \ensuremath  {\mathrm  {HBR}}); only \(\alpha \) differs. \(\Delta \ensuremath  {\mathrm  {CoV}}= 100(\ensuremath  {\mathrm  {CoV}}_{30}-\ensuremath  {\mathrm  {CoV}}_{90})/\ensuremath  {\mathrm  {CoV}}_{90}\), \(\Delta \!|\Delta p| = 100(|\Delta p|_{30}-|\Delta p|_{90})/|\Delta p|_{90}\). Pressure-drop values are LP-filtered per Section~\ref {sec:dp_filter} and carry an estimated \(\pm \SI {0.5}{\kilo \pascal }\) per-case uncertainty; the percentage columns therefore have a \(\pm 30\,\%\) sliding band at the smallest absolute pressure drops, although the rank ordering is robust at every \ensuremath  {d/D}{}.}}{23}{table.caption.24}\protected@file@percent }
\newlabel{tab:matched}{{8}{23}{Matched-pair angle effect. Each pair shares the independent \((\dD ,\VR )\) (and therefore the derived \HBR ); only \(\alpha \) differs. \(\Delta \CoV = 100(\CoV _{30}-\CoV _{90})/\CoV _{90}\), \(\Delta \!|\Delta p| = 100(|\Delta p|_{30}-|\Delta p|_{90})/|\Delta p|_{90}\). Pressure-drop values are LP-filtered per Section~\ref {sec:dp_filter} and carry an estimated \(\pm \SI {0.5}{\kilo \pascal }\) per-case uncertainty; the percentage columns therefore have a \(\pm 30\,\%\) sliding band at the smallest absolute pressure drops, although the rank ordering is robust at every \dD {}}{table.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Matched-pair angle effect. Each pair shares the independent \((\ensuremath  {d/D},\ensuremath  {\mathrm  {VR}})\) (and therefore the derived \ensuremath  {\mathrm  {HBR}}); only \(\alpha \) differs. Green arrows indicate that the \(30^\circ \) case is better than the \(90^\circ \) case on that metric. The tilt reduces \ensuremath  {\mathrm  {CoV}}{} and \(|\Delta p_{\mathrm  {rgh}}|\) in every pair.}}{24}{figure.caption.25}\protected@file@percent }
\newlabel{fig:paired_comparison}{{8}{24}{Matched-pair angle effect. Each pair shares the independent \((\dD ,\VR )\) (and therefore the derived \HBR ); only \(\alpha \) differs. Green arrows indicate that the \(30^\circ \) case is better than the \(90^\circ \) case on that metric. The tilt reduces \CoV {} and \(|\Delta p_{\mathrm {rgh}}|\) in every pair}{figure.caption.25}{}}
