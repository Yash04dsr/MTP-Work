FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
dimensions  [0 2 -2 0 0 0 0];
internalField   uniform 0.375;

// DoE tokens (replaced per-case by stamp_cases.py) :
//    @K_MAIN@     = 1.5 * (I_main * UMAIN)^2
//    @K_BRANCH@   = 1.5 * (I_branch * UBRANCH)^2
// Turbulence intensity I = 5 % is the standard assumption for internal
// pipe flow at Re > 10^5 (Versteeg & Malalasekera 2007, sec. 6.3).

boundaryField
{
    main_inlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform @K_MAIN@;
    }
    branch_inlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform @K_BRANCH@;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform @K_MAIN@;
        value           uniform @K_MAIN@;
    }
    wall
    {
        type            kqRWallFunction;
        value           uniform @K_MAIN@;
    }
    sym { type symmetryPlane; }
}
