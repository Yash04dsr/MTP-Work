FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Kept in-sync with constant/turbulenceProperties so neither is silently
// misread by future solver versions.  rhoReactingBuoyantFoam (v2406) reads
// turbulenceProperties; this file exists for forward compatibility with
// solvers that use the newer foundation-branch naming convention.

simulationType  RAS;

RAS
{
    RASModel        kOmegaSST;
    turbulence      on;
    printCoeffs     on;
}

