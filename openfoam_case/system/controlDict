FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     reactingFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         5;          // 25000 steps x 2e-4 s = 5 s total

deltaT          2e-4;       // CFL ~ 1.3

writeControl    adjustableRunTime;
writeInterval   0.1;        // save every 0.1 s (= 500 steps)

purgeWrite      0;
writeFormat     binary;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   6;

runTimeModifiable true;

// ── Function objects (monitors) ─────────────────────────────────────
functions
{
    // ── Residual monitor ────────────────────────────────────────────
    residuals
    {
        type            solverInfo;
        libs            (utilityFunctionObjects);
        writeControl    timeStep;
        writeInterval   1;
        fields          (U p h nuTilda H2);
    }

    // ── Mass flow rate at outlet ────────────────────────────────────
    outletMassFlow
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);
        writeControl    timeStep;
        writeInterval   1;
        surfaceFormat   none;
        regionType      patch;
        name            outlet;
        operation       sum;
        fields          (phi);
    }

    // ── Mass flow rate at main inlet ────────────────────────────────
    mainInletMassFlow
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);
        writeControl    timeStep;
        writeInterval   1;
        surfaceFormat   none;
        regionType      patch;
        name            main_inlet;
        operation       sum;
        fields          (phi);
    }

    // ── Mass-weighted average H2 at outlet ──────────────────────────
    outletH2
    {
        type            surfaceFieldValue;
        libs            (fieldFunctionObjects);
        writeControl    timeStep;
        writeInterval   1;
        surfaceFormat   none;
        regionType      patch;
        name            outlet;
        operation       weightedAverage;
        weightField     phi;
        fields          (H2);
    }

    // ── Point monitors: wall H2 at pipe top (y=+0.23) ──────────────
    wallH2Probes
    {
        type            probes;
        libs            (sampling);
        writeControl    timeStep;
        writeInterval   1;
        fields          (H2);
        probeLocations
        (
            (0 0.23 5.52)   // z/d1 = 2
            (0 0.23 6.44)   // z/d1 = 4
            (0 0.23 7.36)   // z/d1 = 6
            (0 0.23 8.28)   // z/d1 = 8
        );
    }

    // ── Time-averaged fields (enabled at t = 4 s) ───────────────────
    fieldAverage1
    {
        type            fieldAverage;
        libs            (fieldFunctionObjects);
        writeControl    writeTime;
        timeStart       4.0;    // start averaging after 20000 steps

        fields
        (
            U
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            p
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
            H2
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            T
            {
                mean        on;
                prime2Mean  off;
                base        time;
            }
        );
    }
}
